    <!-- HTML5 QR Code Scanner Library (Clean, reliable CDN without strict SRI hashes that cause blocking) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html5-qrcode/2.3.8/html5-qrcode.min.js"></script>
    <style>
        /* Custom styled QR scanner layout overriding default library look */
        #reader {
            border: none !important;
            border-radius: 1rem;
            overflow: hidden;
        }
        #reader video {
            object-fit: cover !important;
            border-radius: 1rem;
        }
        /* Custom scanning animation line */
        .scan-laser {
            position: absolute;
            left: 5%;
            width: 90%;
            height: 3px;
            background: linear-gradient(to right, transparent, #3b82f6, #60a5fa, #3b82f6, transparent);
            box-shadow: 0 0 12px 3px rgba(59, 130, 246, 0.7);
            animation: scan 2s linear infinite;
            z-index: 10;
            pointer-events: none;
        }
        @keyframes scan {
            0% { top: 10%; }
            50% { top: 90%; }
            100% { top: 10%; }
        }
    </style>
