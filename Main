        <!-- Main Scanning Workspace -->
        <main class="space-y-6 flex-grow flex flex-col justify-center">
            
            <!-- Camera Viewfinder Card -->
            <div class="relative bg-slate-800/50 backdrop-blur-md rounded-2xl border border-slate-700/50 p-4 shadow-xl overflow-hidden flex flex-col justify-center min-h-[300px]">
                
                <!-- Laser line (Only active when scanning) -->
                <div id="laserLine" class="scan-laser hidden"></div>

                <!-- Scanner Element -->
                <div id="reader" class="w-full bg-slate-950 rounded-xl"></div>
                
                <!-- Custom Fallback / Permission State Message -->
                <div id="scannerPlaceholder" class="flex flex-col items-center justify-center text-center p-8 space-y-4">
                    <div class="p-4 bg-slate-700/30 rounded-full text-slate-400">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                        </svg>
                    </div>
                    <div>
                        <p class="text-base font-medium text-slate-300">Camera access is required</p>
                        <p class="text-xs text-slate-500 max-w-xs mt-1">Tap the button below to grant permission and initiate the camera scanner.</p>
                    </div>
                    <button id="startScanBtn" class="px-5 py-2.5 bg-blue-600 hover:bg-blue-500 active:scale-95 transition text-white font-medium rounded-xl text-sm shadow-lg shadow-blue-500/20 flex items-center gap-2">
                        Start Camera Scanner
                    </button>
                </div>

                <!-- Diagnostic Info Card (Triggered if camera is blocked/fails) -->
                <div id="diagnosticCard" class="hidden flex flex-col items-center justify-center text-center p-6 space-y-4">
                    <div class="p-3 bg-red-500/10 rounded-full text-red-400 border border-red-500/20">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                        </svg>
                    </div>
                    <div class="space-y-2">
                        <h4 class="text-md font-bold text-red-400">Camera Permission Blocked</h4>
                        <p class="text-xs text-slate-300 leading-relaxed max-w-xs mx-auto">
                            Google Sites restricts nested live camera access inside their page embeds.
                        </p>
                        <div class="text-left text-xs bg-slate-900/60 p-3 rounded-lg space-y-2 border border-slate-700/30 text-slate-400">
                            <p><strong>Option A:</strong> Use the green "Upload / Snap QR Image" button below to take a picture of the QR code with your phone!</p>
                            <p><strong>Option B:</strong> Open this scanner outside Google Sites directly in your Safari/Chrome browser.</p>
                        </div>
                    </div>
                    <button id="retryScanBtn" class="px-4 py-2 bg-slate-700 hover:bg-slate-600 transition text-slate-200 font-medium rounded-lg text-xs">
                        Try Again
                    </button>
                </div>

                <!-- Active Control bar (hidden until scanner starts) -->
                <div id="controlBar" class="hidden mt-4 flex justify-between items-center gap-2 border-t border-slate-700/50 pt-3">
                    <button id="switchCamBtn" class="flex-1 py-2 px-3 bg-slate-700/50 hover:bg-slate-700 text-slate-200 text-xs font-medium rounded-lg transition flex items-center justify-center gap-1.5">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 15.89M9 11l3 3L21 4" />
                        </svg>
                        Flip Camera
                    </button>
                    <button id="stopScanBtn" class="flex-1 py-2 px-3 bg-red-900/40 hover:bg-red-900/60 text-red-200 text-xs font-medium rounded-lg transition flex items-center justify-center gap-1.5 border border-red-500/20">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                        Stop Scan
                    </button>
                </div>

            </div>

            <!-- Image Upload Trigger (Highly Optimized Fallback) -->
            <div class="text-center bg-slate-800/25 p-4 rounded-xl border border-slate-700/40">
                <p class="text-xs text-slate-400 mb-2.5">Take a photo or upload an image instead:</p>
                <label class="inline-flex items-center gap-2 px-5 py-3 bg-emerald-600 hover:bg-emerald-500 active:scale-95 cursor-pointer text-white text-sm font-semibold rounded-xl shadow-lg shadow-emerald-950/30 transition">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    Upload / Snap QR Image
                    <input type="file" id="qrFileInput" accept="image/*" class="hidden">
                </label>
            </div>

            <!-- Dynamic Scan Results Modal/Card -->
            <div id="resultCard" class="hidden bg-slate-800 border-2 border-emerald-500/30 rounded-2xl p-5 shadow-2xl relative overflow-hidden transition-all duration-300">
                <div class="absolute top-0 left-0 right-0 h-1.5 bg-emerald-500"></div>
                <div class="flex items-start gap-4">
                    <div class="p-2.5 bg-emerald-500/10 rounded-xl text-emerald-400">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <div class="flex-grow space-y-1.5">
                        <h3 class="text-sm font-bold text-slate-300 uppercase tracking-wider">Scanned Result</h3>
                        <p id="resultText" class="text-base text-white font-mono break-all selection:bg-emerald-500/30"></p>
                    </div>
                </div>

                <!-- Action Toolbar -->
                <div class="mt-4 flex gap-2 border-t border-slate-700/50 pt-4">
                    <button id="copyBtn" class="flex-1 py-2.5 px-4 bg-slate-700 hover:bg-slate-600 active:scale-95 text-slate-200 text-sm font-medium rounded-xl transition flex items-center justify-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
                        </svg>
                        Copy Result
                    </button>
                    <a id="actionLinkBtn" target="_blank" class="hidden flex-1 py-2.5 px-4 bg-blue-600 hover:bg-blue-500 active:scale-95 text-white text-sm font-medium rounded-xl transition flex items-center justify-center gap-2 text-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                        </svg>
                        Open Link
                    </a>
                </div>
            </div>

            <!-- Scan History Accordion -->
            <div class="bg-slate-800/30 border border-slate-700/50 rounded-2xl p-4">
                <div class="flex justify-between items-center mb-3">
                    <h3 class="text-sm font-semibold text-slate-300 flex items-center gap-1.5">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        Scan History
                    </h3>
                    <button id="clearHistoryBtn" class="text-xs text-red-400 hover:text-red-300 transition hidden">Clear All</button>
                </div>
                <div id="historyList" class="space-y-2 max-h-36 overflow-y-auto pr-1 text-xs text-slate-400">
                    <p id="emptyHistoryMsg" class="text-center py-4 text-slate-500 italic">No previous scans found</p>
                </div>
            </div>

        </main>

        <!-- Toast Notifications (No standard alerts used) -->
        <div id="toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 transform scale-90 opacity-0 pointer-events-none transition-all duration-300 px-4 py-2 bg-slate-850 border border-blue-500/30 text-blue-200 text-xs font-semibold rounded-full shadow-lg z-50 flex items-center gap-2">
            <span id="toastMessage">Action performed successfully</span>
        </div>

        <!-- Footer -->
        <footer class="mt-6 text-center text-xs text-slate-500">
            Powered by HTML5-QRCode • Perfect for Mobile & Google Sites
        </footer>
    </div>

    <script>
        // DOM Elements
        const readerEl = document.getElementById('reader');
        const startScanBtn = document.getElementById('startScanBtn');
        const stopScanBtn = document.getElementById('stopScanBtn');
        const retryScanBtn = document.getElementById('retryScanBtn');
        const switchCamBtn = document.getElementById('switchCamBtn');
        const scannerPlaceholder = document.getElementById('scannerPlaceholder');
        const diagnosticCard = document.getElementById('diagnosticCard');
        const controlBar = document.getElementById('controlBar');
        const laserLine = document.getElementById('laserLine');
        const resultCard = document.getElementById('resultCard');
        const resultText = document.getElementById('resultText');
        const copyBtn = document.getElementById('copyBtn');
        const actionLinkBtn = document.getElementById('actionLinkBtn');
        const qrFileInput = document.getElementById('qrFileInput');
        const historyList = document.getElementById('historyList');
        const emptyHistoryMsg = document.getElementById('emptyHistoryMsg');
        const clearHistoryBtn = document.getElementById('clearHistoryBtn');
        const toast = document.getElementById('toast');
        const toastMessage = document.getElementById('toastMessage');

        let html5QrCode = null;
        let currentFacingMode = "environment"; // Try back camera first on mobile
        let history = JSON.parse(localStorage.getItem('qr_history') || '[]');

        // Initialize App & History List
        renderHistory();

        // Start scanning click handlers
        startScanBtn.addEventListener('click', () => {
            initScanner();
        });
        
        retryScanBtn.addEventListener('click', () => {
            diagnosticCard.classList.add('hidden');
            initScanner();
        });

        // Initialize scanner logic
        function initScanner() {
            // Guard: check if the HTML5 QR Code library successfully loaded
            if (typeof Html5Qrcode === 'undefined') {
                showToast("Scanning library failed to load. Check your internet connection.");
                showDiagnostics();
                return;
            }

            // Instantiate library element if not exists
            if (!html5QrCode) {
                html5QrCode = new Html5Qrcode("reader");
            }

            // Hide placeholder and diagnostics, display scanner elements
            scannerPlaceholder.classList.add('hidden');
            diagnosticCard.classList.add('hidden');
            controlBar.classList.remove('hidden');
            laserLine.classList.remove('hidden');

            const config = { 
                fps: 15, 
                qrbox: function(width, height) {
                    const minDimension = Math.min(width, height);
                    const boxSize = Math.floor(minDimension * 0.70);
                    return { width: boxSize, height: boxSize };
                },
                aspectRatio: 1.0 
            };

            html5QrCode.start(
                { facingMode: currentFacingMode },
                config,
                onScanSuccess,
                onScanFailure
            ).catch(err => {
                console.warn("Camera start failed: ", err);
                showDiagnostics();
            });
        }

        // Show diagnostics screen when camera initialization fails (e.g. iframe permission blockage)
        function showDiagnostics() {
            controlBar.classList.add('hidden');
            laserLine.classList.add('hidden');
            scannerPlaceholder.classList.add('hidden');
            diagnosticCard.classList.remove('hidden');
        }

        // Stop scanning logic
        function stopScanner() {
            if (html5QrCode && html5QrCode.isScanning) {
                html5QrCode.stop().then(() => {
                    resetUI();
                }).catch(err => {
                    console.error("Failed to stop scanner smoothly", err);
                    resetUI();
                });
            } else {
                resetUI();
            }
        }

        function resetUI() {
            scannerPlaceholder.classList.remove('hidden');
            diagnosticCard.classList.add('hidden');
            controlBar.classList.add('hidden');
            laserLine.classList.add('hidden');
        }

        stopScanBtn.addEventListener('click', stopScanner);

        // Switch Camera (Flip facing mode)
        switchCamBtn.addEventListener('click', () => {
            if (html5QrCode && html5QrCode.isScanning) {
                currentFacingMode = currentFacingMode === "environment" ? "user" : "environment";
                html5QrCode.stop().then(() => {
                    initScanner(); // restart with new facing mode
                });
            }
        });

        // Handle scanned code success
        function onScanSuccess(decodedText, decodedResult) {
            // Vibrate device if supported
            if (navigator.vibrate) {
                navigator.vibrate(100);
            }
            
            displayResult(decodedText);
            saveToHistory(decodedText);
            stopScanner();
        }

        // Handle scan failure (fires continuously while scanning, safe to ignore logs)
        function onScanFailure(error) {
            // Silent fallback to avoid flooding console performance
        }

        // Process file upload logic
        qrFileInput.addEventListener('change', e => {
            if (e.target.files.length === 0) return;
            
            if (typeof Html5Qrcode === 'undefined') {
                showToast("Library not loaded. Please reload the page.");
                return;
            }

            const file = e.target.files[0];
            const tempScanner = new Html5Qrcode("reader");
            
            showToast("Reading file...");
            tempScanner.scanFile(file, true)
                .then(decodedText => {
                    displayResult(decodedText);
                    saveToHistory(decodedText);
                    showToast("QR Code successfully parsed!");
                })
                .catch(err => {
                    showToast("No readable QR code found in image.");
                });
        });

        // Render result actions
        function displayResult(text) {
            resultText.textContent = text;
            resultCard.classList.remove('hidden');

            // Check if string is a valid URL
            const isUrl = isValidUrl(text);
            if (isUrl) {
                actionLinkBtn.href = text;
                actionLinkBtn.classList.remove('hidden');
            } else {
                actionLinkBtn.classList.add('hidden');
            }

            // Scroll result view into viewport
            resultCard.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }

        // Fallback helper for copying text to clipboard safely inside Google Sites iframe
        copyBtn.addEventListener('click', () => {
            const textToCopy = resultText.textContent;
            
            // Standard backup manual select/execute command
            const textArea = document.createElement("textarea");
            textArea.value = textToCopy;
            textArea.style.top = "0";
            textArea.style.left = "0";
            textArea.style.position = "fixed";
            document.body.appendChild(textArea);
            textArea.focus();
            textArea.select();
            
            try {
                document.execCommand('copy');
                showToast("Copied to clipboard!");
            } catch (err) {
                showToast("Could not copy. Please select text manually.");
            }
            document.body.removeChild(textArea);
        });

        // History Management
        function saveToHistory(text) {
            const timestamp = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            
            // Avoid adding identical consecutive duplicates
            if (history.length === 0 || history[0].text !== text) {
                history.unshift({ text, time: timestamp });
                if (history.length > 20) history.pop(); // cap history list
                localStorage.setItem('qr_history', JSON.stringify(history));
                renderHistory();
            }
        }

        function renderHistory() {
            if (history.length === 0) {
                emptyHistoryMsg.classList.remove('hidden');
                clearHistoryBtn.classList.add('hidden');
                historyList.innerHTML = '';
                historyList.appendChild(emptyHistoryMsg);
                return;
            }

            emptyHistoryMsg.classList.add('hidden');
            clearHistoryBtn.classList.remove('hidden');

            historyList.innerHTML = history.map((item, index) => `
                <div class="flex justify-between items-start bg-slate-800/60 border border-slate-700/40 p-2.5 rounded-xl hover:bg-slate-800 transition cursor-pointer" onclick="displayResult('${escapeJS(item.text)}')">
                    <span class="truncate font-mono pr-2 text-slate-200 select-all flex-grow text-left">${escapeHTML(item.text)}</span>
                    <span class="text-[10px] text-slate-500 whitespace-nowrap pt-0.5">${item.time}</span>
                </div>
            `).join('');
        }

        clearHistoryBtn.addEventListener('click', () => {
            history = [];
            localStorage.removeItem('qr_history');
            renderHistory();
            showToast("Scan history cleared.");
        });

        // Toast Helper
        function showToast(message) {
            toastMessage.textContent = message;
            toast.classList.remove('scale-90', 'opacity-0', 'pointer-events-none');
            toast.classList.add('scale-100', 'opacity-100');
            
            setTimeout(() => {
                toast.classList.remove('scale-100', 'opacity-100');
                toast.classList.add('scale-90', 'opacity-0', 'pointer-events-none');
            }, 3000);
        }

        // Utility: URL check
        function isValidUrl(string) {
            try {
                new URL(string);
                return true;
            } catch (_) {
                return false;  
            }
        }

        // Utility: Sanitizers
        function escapeHTML(str) {
            return str.replace(/[&<>'"]/g, 
                tag => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[tag] || tag)
            );
        }

        function escapeJS(str) {
            return str.replace(/'/g, "\\'").replace(/"/g, '\\"');
        }
    </script>
</body>
</html>
